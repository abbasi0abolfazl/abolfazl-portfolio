{
  "name": "Comment",
  "type": "object",
  "properties": {
    "post_slug": {
      "type": "string",
      "description": "Slug of the blog post this comment belongs to"
    },
    "author_name": {
      "type": "string",
      "description": "Display name of the commenter"
    },
    "author_email": {
      "type": "string",
      "description": "Email of the commenter (not displayed publicly)"
    },
    "content": {
      "type": "string",
      "description": "Comment text"
    },
    "published": {
      "type": "boolean",
      "default": false,
      "description": "Moderation flag \u2014 only published comments are shown publicly"
    },
    "parent_id": {
      "type": "string",
      "description": "Optional parent comment ID for threaded replies"
    }
  },
  "required": [
    "post_slug",
    "author_name",
    "content"
  ]
}